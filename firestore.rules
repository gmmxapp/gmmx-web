rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Initial setup rules: Allow anyone to register
    match /gyms/{gymId} {
      allow create: if true;
      allow read: if true;
    }
    match /users/{userId} {
      allow create: if true;
      allow read, write: if true;
    }
  }
}
